{
  "name": "gallerypack",
  "version": "1.4.0",
  "description": "Deliver photo galleries fast.",
  "workspaces": [
    "packages/*",
    "apps/*",
    "workers/*"
  ],
  "scripts": {
    "dev:api":    "node apps/api/src/server.js",
    "dev:worker": "node workers/builder/src/index.js",
    "test":       "node --test apps/api/test/"
  },
  "type": "module"
}
