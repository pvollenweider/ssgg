{
  "name": "gallerypack",
  "version": "1.3.0",
  "description": "Turn a folder of photos into a polished, self-contained static gallery — in one command.",
  "workspaces": [
    "packages/*",
    "apps/*",
    "workers/*"
  ],
  "scripts": {
    "new-gallery": "node build/create-gallery.js",
    "new-gallery:wizard": "node build/create-gallery.js --wizard",
    "build": "node build/index.js",
    "build:force": "node build/index.js --force",
    "build:all": "node build/index.js --all",
    "build:clean": "rm -rf dist && node build/index.js --all",
    "clean": "rm -rf dist",
    "setup:example": "node build/generate-samples.js",
    "setup:example:force": "node build/generate-samples.js --force",
    "serve": "node build/serve.js",
    "dev": "node server/app.js",
    "deploy": "bash scripts/deploy-gh-pages.sh",
    "export": "node build/export.js",
    "export:zip": "node build/export.js --zip",
    "publish": "node build/publish.js",
    "publish:all": "node build/publish.js --all",
    "test": "node --test test/"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.16",
    "piexifjs": "^1.0.6",
    "sharp": "^0.33.5"
  },
  "type": "module"
}
