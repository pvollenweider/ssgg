# GalleryPack — Secret manifest example
# DO NOT commit secrets.yml with real values.
# secrets.yml is in .gitignore.
#
# To create the secret from your .env file:
#   kubectl create secret generic gallerypack-app-secrets \
#     --from-literal=SESSION_SECRET=<value> \
#     --from-literal=VIEWER_TOKEN_SECRET=<value> \
#     --from-literal=DB_PASS=<value> \
#     --from-literal=DB_ROOT_PASSWORD=<value> \
#     --from-literal=ADMIN_PASSWORD=<value>
#
# To use sealed-secrets (recommended for GitOps):
#   kubeseal --format yaml < secrets.yml > sealed-secrets.yml

---
apiVersion: v1
kind: Secret
metadata:
  name: gallerypack-app-secrets
  labels:
    app: gallerypack
type: Opaque
stringData:
  SESSION_SECRET: "change-me"
  VIEWER_TOKEN_SECRET: "change-me"
  DB_PASS: "change-me"
  DB_ROOT_PASSWORD: "change-me"
  ADMIN_PASSWORD: "change-me"
