{
  "name": "gallerypack",
  "version": "1.7.0",
  "description": "Deliver photo galleries fast.",
  "workspaces": [
    "packages/*",
    "apps/*",
    "workers/*"
  ],
  "scripts": {
    "dev:api":    "node apps/api/src/server.js",
    "dev:worker": "node workers/builder/src/index.js",
    "test":       "node --test apps/api/test/"
  },
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "overrides": {
    "srvx": ">=0.11.13",
    "esbuild": ">=0.25.0",
    "lodash": "4.18.1"
  }
}
