# GalleryPack — Production environment variables
# Copy to deploy/.env and fill in your values.

# Admin panel password
ADMIN_PASSWORD=change-me

# Random secret for session tokens (generate with: openssl rand -hex 32)
SESSION_SECRET=change-this-to-a-random-secret

# Public URL of the site (no trailing slash)
BASE_URL=https://galleries.example.com

# Apache document root on this server — used when generating .htaccess files
# for password-protected galleries. Must match Apache's DocumentRoot below.
GALLERY_APACHE_PATH=/var/www/galleries/dist

# Optional SMTP (for email notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=secret
# SMTP_FROM=GalleryPack <noreply@example.com>
# ADMIN_EMAIL=admin@example.com
