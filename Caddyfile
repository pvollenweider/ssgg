# Caddyfile - GalleryPack SaaS production reverse proxy
# The admin SPA and API are both served by the Express API container.
#
# Multi-studio mode: set BASE_DOMAIN=gallerypack.app in environment.
# Caddy passes the original Host header as X-Forwarded-Host so the API can
# resolve the studio context from the subdomain.
#
# Wildcard subdomain block (multi-studio):
#   *.{$BASE_DOMAIN:localhost} — studio subdomains
# Root domain block:
#   {$BASE_DOMAIN:localhost}   — platform root

# ── Studio subdomains (only active when BASE_DOMAIN is set) ───────────────────
http://*.{$BASE_DOMAIN:localhost} {
    reverse_proxy api:4000 {
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-For  {remote_host}
        flush_interval -1
    }

    encode gzip

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options        "SAMEORIGIN"
        Referrer-Policy        "strict-origin-when-cross-origin"
        -Server
    }
}

# ── Platform root / single-domain fallback ────────────────────────────────────
:80 {
    # Thumbnails — served directly by Caddy (no Node.js overhead)
    handle /media/thumbnails/* {
        uri strip_prefix /media
        root * /srv/gallerypack/internal
        file_server {
            precompressed br gzip
        }
        header Cache-Control "public, max-age=604800, immutable"
    }

    # API + Admin SPA
    handle /api/* {
        reverse_proxy api:4000 {
            header_up X-Forwarded-For {remote_host}
            # Disable buffering for SSE streams
            flush_interval -1
        }
    }

    handle /admin* {
        reverse_proxy api:4000
    }

    # Built galleries — only the public tier is mounted here; internal/ and private/ are not
    handle /* {
        root * /srv/gallerypack/public
        # Rewrite directory requests to their index.html so the file matcher works
        try_files {path} {path}/index.html
        file_server {
            precompressed br gzip
        }
        # Fall back to API for galleries not yet built
        @missing not file
        handle @missing {
            reverse_proxy api:4000
        }
    }

    # Exclude SSE streams from gzip — encode buffers responses before compressing,
    # which breaks Server-Sent Events (infinite response, never "complete").
    @not_sse not path /api/*/stream
    encode @not_sse gzip

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options        "SAMEORIGIN"
        Referrer-Policy        "strict-origin-when-cross-origin"
        -Server
        # Note: no Content-Security-Policy header - Vite bundles inline scripts
        # that require 'unsafe-inline'. CSP can be added once the app uses nonces.
    }
}
