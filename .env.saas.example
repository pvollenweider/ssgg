# GalleryPack SaaS — environment variables
# Copy to .env and fill in required values before running docker-compose.saas.yml

# ── Required ──────────────────────────────────────────────────────────────────

# Admin account password (created on first start if no users exist)
ADMIN_PASSWORD=change-me

# Signs admin session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=change-me

# ── Production (set for any public deployment) ─────────────────────────────────

# Your public domain — Caddy provisions TLS automatically via Let's Encrypt
DOMAIN=localhost

# Full public URL (used in invite emails and gallery links)
BASE_URL=http://localhost

# Signs gallery viewer tokens — generate with: openssl rand -hex 32
VIEWER_TOKEN_SECRET=change-me-in-production

# ── Storage ────────────────────────────────────────────────────────────────────

# local (default) or s3
STORAGE_DRIVER=local

# Root path for local storage (inside the container — mapped to ./storage on host)
STORAGE_ROOT=/app/storage

# S3 / R2 / MinIO — only needed when STORAGE_DRIVER=s3
# S3_BUCKET=gallerypack
# S3_REGION=auto
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── Email ──────────────────────────────────────────────────────────────────────

# null = log to console (dev), smtp = send via SMTP
EMAIL_PROVIDER=null

# SMTP settings — only needed when EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false        # true for port 465
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=GalleryPack <noreply@photos.example.com>
