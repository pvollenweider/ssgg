# =============================================================================
# GalleryPack — Environment Variables
# =============================================================================
# Copy this file to .env and edit the values.
# Variables marked [REQUIRED] must be set before first boot.
# Variables marked [RECOMMENDED] should be changed for production.
# All others have sensible defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Platform
# -----------------------------------------------------------------------------

# Platform mode: "single" (one organization) or "multi" (multi-tenant with
# subdomain routing). Default: single
PLATFORM_MODE=single

# Public URL used in emails, invitation links, and gallery URLs.
# [RECOMMENDED] Change for production.
BASE_URL=http://localhost

# Root domain for subdomain-based organization routing (multi mode only).
# Each organization gets <slug>.BASE_DOMAIN. Not used in single mode.
# BASE_DOMAIN=gallerypack.app

# Domain name for TLS certificate provisioning (Caddy).
# Set this to your production domain for automatic Let's Encrypt certs.
# DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# Bootstrap admin account
# -----------------------------------------------------------------------------

# Email address for the initial admin account created on first boot.
ADMIN_EMAIL=admin@localhost

# Password for the initial admin account.
# [REQUIRED] Choose a strong password.
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------

# Signs session cookies. Generate with: openssl rand -hex 32
# [REQUIRED]
SESSION_SECRET=

# Signs viewer tokens for private gallery access.
# [RECOMMENDED] Change from default in production.
VIEWER_TOKEN_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# Database (MariaDB)
# -----------------------------------------------------------------------------

# MariaDB host. Use "db" when running inside Docker Compose (service name).
DB_HOST=db

# MariaDB port.
DB_PORT=3306

# Database name.
DB_NAME=gallerypack

# Database user.
DB_USER=gallerypack

# Database password for the application user.
# [REQUIRED]
DB_PASS=

# MariaDB root password. Required by the db service in Docker Compose.
# [REQUIRED]
DB_ROOT_PASSWORD=

# Connection pool size. Default: 10
# DB_POOL_SIZE=10

# Enable TLS for the database connection. Default: false
# DB_SSL=false

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Redis connection URL. Default uses the "redis" service name from Compose.
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Storage driver: "local" (filesystem) or "s3" (S3-compatible).
STORAGE_DRIVER=local

# Root path for local storage inside the container.
STORAGE_ROOT=/srv/gallerypack

# S3-compatible storage settings (only when STORAGE_DRIVER=s3).
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------

# Email provider: "null" (log to console) or "smtp" (send via SMTP).
EMAIL_PROVIDER=null

# SMTP settings (only when EMAIL_PROVIDER=smtp).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=GalleryPack <noreply@example.com>
# SMTP_SECURE=false

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# API listen port inside the container. Default: 4000
PORT=4000

# Node environment. Default: production
NODE_ENV=production

# Pino log level: trace, debug, info, warn, error. Default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Upload limits
# -----------------------------------------------------------------------------

# Maximum file size per upload in MB. Default: 100
UPLOAD_MAX_SIZE_MB=100

# Maximum number of photos per gallery. Default: 500
GALLERY_MAX_PHOTOS=500

# Upload throttle profile: "dev" (unlimited) or "prod" (bandwidth-limited).
# UPLOAD_THROTTLE_PROFILE=dev

# Maximum upload bandwidth in Mbps (overrides profile if set).
# UPLOAD_MAX_BANDWIDTH_MBPS=

# TTL in hours for incomplete tus uploads before cleanup. Default: 24
# TUS_UPLOAD_TTL_H=24

# -----------------------------------------------------------------------------
# Worker concurrency
# -----------------------------------------------------------------------------

# Number of concurrent thumbnail generation jobs. Default: 4
THUMB_CONCURRENCY=4

# Number of concurrent gallery prerender jobs. Default: 2
PRERENDER_CONCURRENCY=2

# -----------------------------------------------------------------------------
# License
# -----------------------------------------------------------------------------

# Path to the license file inside the container.
LICENSE_FILE=/app/data/gallerypack.license

# Default organization name on first boot. Default: Default
# STUDIO_NAME=Default

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking. Leave unset to disable Sentry.
# SENTRY_DSN=

# Sentry release identifier. Defaults to package version.
# SENTRY_RELEASE=

# Application version (used in health endpoint and logs).
# APP_VERSION=
